{
  "name": "archivage-system",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "artifacts/*",
    "lib/*",
    "scripts"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev --workspace=@workspace/api-server\" \"npm run dev --workspace=@workspace/archivage-app\"",
    "dev:win": "run-dev.bat",
    "install:all": "npm install && npm run build --workspaces",
    "build": "npm run typecheck && npm run build --workspaces --if-present",
    "start": "npm start --workspace=@workspace/api-server",
    "typecheck:libs": "tsc --build",
    "typecheck": "npm run typecheck:libs && npm run typecheck --workspaces --if-present"
  },
  "devDependencies": {
    "typescript": "~5.9.2",
    "prettier": "^3.8.1",
    "concurrently": "^9.1.2"
  }
}
