{
  "name": "@workspace/api-server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
   "scripts": {
    "dev": "node ./build.mjs && node --enable-source-maps ./dist/index.mjs",
    "build": "node ./build.mjs",
    "start": "node --enable-source-maps ./dist/index.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "seed": "npm run build && node --enable-source-maps ./dist/run-seed.mjs",
    "seed:clean": "npm run seed"
  },
  "dependencies": {
    "@workspace/api-zod": "*",
    "@workspace/db": "*",
    "bcryptjs": "^3.0.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2",
    "drizzle-orm": "^0.45.1",
    "express": "^5",
    "express-session": "^1.19.0",
    "multer": "^2.1.1",
    "pg": "^8.20.0",
    "pino": "^9",
    "pino-http": "^10",
    "sql.js": "^1.14.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^3.0.0",
    "@types/better-sqlite3": "^7.6.12",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/express-session": "^1.18.2",
    "@types/multer": "^2.1.0",
    "@types/node": "^25.3.3",
    "@types/pg": "^8.18.0",
    "esbuild": "^0.25.8",
    "esbuild-plugin-pino": "^2.3.3",
    "pino-pretty": "^13",
    "thread-stream": "3.1.0"
  }
}
