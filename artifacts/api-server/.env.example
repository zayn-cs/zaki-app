# =============================================================================
# Fichier d'exemple de configuration – API Server
# Copiez ce fichier vers .env et modifiez les valeurs
# =============================================================================

# Base de données PostgreSQL
# Format : postgresql://UTILISATEUR:MOT_DE_PASSE@HOTE:PORT/NOM_BASE
DATABASE_URL=postgresql://votre_utilisateur:votre_mot_de_passe@localhost:5432/votre_base_de_donnees

# Session (clé secrète pour les cookies de session)
SESSION_SECRET=votre-cle-secrete-tres-longue-ici

# Environnement (development | production)
NODE_ENV=development

# Dossier d'upload des fichiers (optionnel)
# UPLOAD_DIR=./uploads

# Port du serveur (optionnel)
# PORT=3000
